  "blob-iobuf": {
    "description": "Buffered BlobDB profile with larger values and GC defaults",
    "key_count_source": "nk_io",
    "env": {
      "VALUE_SIZE": 3200,
      "COMPACTION_STYLE": "blob",
      "COMPRESSION_TYPE": "lz4",
      "BOTTOMMOST_COMPRESSION": "disable",
      "BLOB_COMPRESSION_TYPE": "lz4",
      "BLOB_GC_AGE_CUTOFF": 0.25,
      "BLOB_GC_FORCE_THRESHOLD": 1,
      "USE_O_DIRECT": 0,
      "CACHE_INDEX_AND_FILTER_BLOCKS": 1
    }
  },
