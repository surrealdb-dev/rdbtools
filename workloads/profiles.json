{
  "byrx": {
    "description": "Memory-sized RocksDB profile with buffered IO and no compression",
    "key_count_source": "nk_mem",
    "env": {
      "VALUE_SIZE": 400,
      "COMPRESSION_TYPE": "none",
      "BOTTOMMOST_COMPRESSION": "disable",
      "USE_O_DIRECT": 0,
      "CACHE_INDEX_AND_FILTER_BLOCKS": 1
    }
  },
  "byos": {
    "description": "OS-cache profile with buffered IO and no compression",
    "key_count_source": "nk_mem",
    "env": {
      "VALUE_SIZE": 400,
      "COMPRESSION_TYPE": "none",
      "BOTTOMMOST_COMPRESSION": "disable",
      "USE_O_DIRECT": 0,
      "CACHE_INDEX_AND_FILTER_BLOCKS": 0
    }
  },
  "iobuf": {
    "description": "Larger IO-sized buffered profile, commonly used with lz4",
