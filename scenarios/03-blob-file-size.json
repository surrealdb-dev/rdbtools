{
  "name": "blob-file-size",
  "description": "Focused BlobDB file size sweep for 16 MiB, 64 MiB, and 128 MiB.",
  "binary_dir": "bin",
  "binaries": ["10.6.clang"],
  "db_dir": "/data/m/rx",
  "output_dir": "runs/blob-file-size",
  "machine": "c8r16",
  "workloads": ["iobuf"],
  "pipeline": "lsm-default",
  "baseline": {
    "NUM_THREADS": 1,
    "NUM_KEYS": 40000000,
    "VALUE_SIZE": 400,
    "DURATION_RW": 30,
    "DURATION_RO": 30,
    "COMPACTION_STYLE": "blob",
    "WRITE_BUFFER_SIZE_MB": 16,
    "TARGET_FILE_SIZE_BASE_MB": 16,
    "MAX_BYTES_FOR_LEVEL_BASE_MB": 64,
    "MAX_BACKGROUND_JOBS": 4,
    "MIN_LEVEL_TO_COMPRESS": 3,
    "CACHE_INDEX_AND_FILTER_BLOCKS": 1,
    "BLOB_GC_AGE_CUTOFF": 0.25,
    "BLOB_GC_FORCE_THRESHOLD": 1,
    "BLOB_FILE_SIZE": 16777216
  },
  "sweeps": [
    {
      "name": "blob_file_size",
      "mode": "one_at_a_time",
      "params": {
        "BLOB_FILE_SIZE": [16777216, 67108864, 134217728]
      }
    }
  ],
  "execution": {
    "remove_db_before_version": true,
    "cooldown_seconds": 0,
    "smoke": false,
    "clean_env": false
  }
}
