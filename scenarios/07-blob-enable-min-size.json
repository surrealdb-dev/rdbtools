{
  "name": "blob-enable-min-size",
  "description": "SurrealDB-aligned comparison of leveled no-blob control versus BlobDB defaults with larger values.",
  "binary_dir": "bin",
  "binaries": ["10.6.clang"],
  "db_dir": "/data/m/rx",
  "output_dir": "runs/blob-enable-min-size",
  "warnings": [
    "SurrealDB cnf.rs currently defaults compaction_readahead_size to 256 KiB; the provided shell script used 8 MiB, so this scenario follows cnf.rs.",
    "db_bench cannot model SurrealDB prefix extractor, grouped commit, or async scan scheduling behavior."
  ],
  "machine": {},
  "workloads": [
    {
      "name": "surrealdb-buffered-lz4-zstd",
      "env": {
        "COMPRESSION_TYPE": "lz4",
        "BOTTOMMOST_COMPRESSION": "zstd",
        "USE_O_DIRECT": 0
      }
    }
  ],
  "pipeline": "lsm-default",
  "baseline": {
    "NUM_THREADS": 1,
    "NUM_KEYS": 10000000,
    "VALUE_SIZE": 8192,
    "NUM_NEXTS_PER_SEEK": 10,
    "DURATION_RW": 30,
    "DURATION_RO": 30,
    "COMPACTION_STYLE": "leveled",
    "WRITE_BUFFER_SIZE_MB": 64,
    "TARGET_FILE_SIZE_BASE_MB": 64,
    "TARGET_FILE_SIZE_MULTIPLIER": 2,
    "MAX_BYTES_FOR_LEVEL_BASE_MB": 256,
    "MAX_BACKGROUND_JOBS": 4,
    "SUBCOMPACTIONS": 4,
    "PER_LEVEL_FANOUT": 10,
    "LEVEL0_FILE_NUM_COMPACTION_TRIGGER": 4,
    "OPEN_FILES": 1026,
    "BLOCK_SIZE": 65536,
    "CACHE_SIZE_MB": 7168,
    "CACHE_NUMSHARDBITS": 6,
    "BYTES_PER_SYNC": 1048576,
    "METADATA_BLOCK_SIZE": 16384,
    "COMPACTION_READAHEAD_SIZE": 262144,
    "MIN_LEVEL_TO_COMPRESS": 3,
    "CACHE_INDEX_AND_FILTER_BLOCKS": 1
  },
  "sweeps": [
    {
      "name": "blob_enable_min_size",
      "mode": "cases",
      "cases": [
        {
          "id": "blob_surrealdb_default",
          "updates": {
            "COMPACTION_STYLE": "blob",
            "MIN_BLOB_SIZE": 4096,
            "BLOB_FILE_SIZE": 268435456,
            "BLOB_COMPRESSION_TYPE": "snappy",
            "ENABLE_BLOB_GC": 1,
            "BLOB_GC_AGE_CUTOFF": 0.5,
            "BLOB_GC_FORCE_THRESHOLD": 0.5,
            "BLOB_COMPACTION_READAHEAD_SIZE": 0
          }
        }
      ]
    }
  ],
  "execution": {
    "remove_db_before_version": true,
    "cooldown_seconds": 0,
    "smoke": false,
    "clean_env": false
  }
}
