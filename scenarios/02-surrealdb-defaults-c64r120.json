{
  "name": "surrealdb-defaults-c64r120",
  "description": "Baseline run for current SurrealDB RocksDB defaults on the 64-core / 120 GiB benchmark machine. This is not a sweep; it is the control scenario for understanding default behavior across selected workload profiles.",
  "binary_dir": "bin",
  "binaries": ["10.6.clang"],
  "rocksdb_source": "/Users/kfarhan/workspace/surrealdb/rocksdb",
  "db_dir": "/data/m/rx",
  "output_dir": "runs/surrealdb-defaults-c64r120",
  "machine": "c64r120",
  "workloads": ["byrx", "iobuf", "iodir", "blob-iobuf"],
  "pipeline": "lsm-default",
  "nk_mem": 40000000,
  "nk_io": 40000000,
  "baseline": {
    "NUM_THREADS": 64,
    "DURATION_RW": 1800,
    "DURATION_RO": 1800,
    "COMPACTION_STYLE": "blob",
    "COMPRESSION_TYPE": "lz4",
    "BOTTOMMOST_COMPRESSION": "zstd",
    "WRITE_BUFFER_SIZE_MB": 128,
    "MAX_WRITE_BUFFER_NUMBER": 32,
    "MIN_WRITE_BUFFER_NUMBER_TO_MERGE": 2,
    "TARGET_FILE_SIZE_BASE_MB": 64,
    "TARGET_FILE_SIZE_MULTIPLIER": 2,
    "MAX_BYTES_FOR_LEVEL_BASE_MB": 512,
    "LEVEL0_FILE_NUM_COMPACTION_TRIGGER": 4,
    "MAX_BACKGROUND_JOBS": 128,
    "SUBCOMPACTIONS": 4,
    "OPEN_FILES": 1026,
    "BLOCK_SIZE": 65536,
    "CACHE_SIZE_MB": 60416,
    "CACHE_INDEX_AND_FILTER_BLOCKS": 1,
    "PARTITION_INDEX_AND_FILTERS": 1,
    "COMPACTION_READAHEAD_SIZE": 262144,
    "MIN_BLOB_SIZE": 4096,
    "BLOB_FILE_SIZE": 268435456,
    "BLOB_COMPRESSION_TYPE": "snappy",
    "ENABLE_BLOB_GC": 1,
    "BLOB_GC_AGE_CUTOFF": 0.5,
    "BLOB_GC_FORCE_THRESHOLD": 0.5,
    "BLOB_COMPACTION_READAHEAD_SIZE": 0,
    "INITIAL_AUTO_READAHEAD_SIZE": 8192,
    "MAX_AUTO_READAHEAD_SIZE": 4194304,
    "FILE_READS_FOR_AUTO_READAHEAD": 2
  },
  "sweeps": [],
  "execution": {
    "remove_db_before_version": true,
    "cooldown_seconds": 60,
    "smoke": false,
    "clean_env": false
  }
